# Build arguments for Docker
VERSION=dev
BUILD_TIME=$(date -u '+%Y-%m-%d_%H:%M:%S')
GIT_COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
GO_VERSION=$(go version | awk '{print $3}')

# Server Configuration
FUSION_SERVER_HOST=0.0.0.0
FUSION_SERVER_PORT=8080
FUSION_SERVER_READ_TIMEOUT=30s
FUSION_SERVER_WRITE_TIMEOUT=30s

# Database Configuration
FUSION_DATABASE_DSN=postgres://postgres:postgres@localhost:5432/fusion?sslmode=disable
FUSION_DATABASE_MAX_OPEN_CONNS=25
FUSION_DATABASE_MAX_IDLE_CONNS=5
FUSION_DATABASE_CONN_MAX_LIFETIME=300s

# Logger Configuration
FUSION_LOGGER_LEVEL=info
FUSION_LOGGER_ENABLE_CONSOLE=true
FUSION_LOGGER_ENABLE_COLOR=true
FUSION_LOGGER_ENABLE_FILE=false
FUSION_LOGGER_OUTPUT_PATH=./logs/app.log
FUSION_LOGGER_COMPRESS=true
FUSION_LOGGER_MAX_SIZE=100
FUSION_LOGGER_MAX_AGE=30
FUSION_LOGGER_MAX_BACKUPS=10

# JWT Configuration
FUSION_JWT_SECRET=your-secret-key-change-this-in-production
FUSION_JWT_EXPIRATION=12h